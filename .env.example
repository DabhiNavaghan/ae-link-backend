# MongoDB
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<dbname>?appName=<appName>

# Clerk Auth (required — get from https://dashboard.clerk.com)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
CLERK_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard

# Application
NODE_ENV=production
NEXT_PUBLIC_APP_URL=https://your-domain.vercel.app

# Default Tenant Settings
DEFAULT_FINGERPRINT_TTL_HOURS=72
DEFAULT_MATCH_THRESHOLD=70

# Logging
LOG_LEVEL=info

# Rate Limiting (in-memory — works for single-region Vercel; use Redis for multi-region)
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_PUBLIC_REQUESTS=100
RATE_LIMIT_AUTH_REQUESTS=1000

# CORS (comma-separated list of allowed origins)
ALLOWED_ORIGINS=https://allevents.in,https://allevents.app,http://localhost:3000

# Email (Gmail SMTP for team invites)
SMTP_USER=your-email@gmail.com
SMTP_PASS=xxxx xxxx xxxx xxxx
SMTP_FROM_NAME=SmartLink

# Feature Flags
ENABLE_ANALYTICS=true
ENABLE_DEFERRED_LINKING=true
